# Garmin Agent Configuration
# Copy this file to .local/.env for local development.
# Do not commit real credentials or runtime data.

# Garmin credentials are only needed for the first login or token refresh.
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password

# LLM API configuration. Use one provider family.
ANTHROPIC_AUTH_TOKEN=your_api_key_here
ANTHROPIC_BASE_URL=https://api.stepfun.com/step_plan
ANTHROPIC_DEFAULT_FABLE_MODEL=step-3.7-flash

# Alternative Anthropic-compatible GLM configuration.
# ZHIPU_API_KEY=your_api_key_here
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/anthropic
# ZHIPU_MODEL=glm-4.7

# Private runtime root. Defaults to <repo>/.local.
GARMIN_AGENT_HOME=.local

# Optional explicit runtime paths.
# GARMIN_TOKEN_DIR=.local/tokens
# GARMIN_CACHE_DIR=.local/cache
# GARMIN_DATA_DIR=.local/data
# GARMIN_LOG_DIR=.local/logs
# GARMIN_MEMORY_DIR=.local/memory
# GARMIN_OUTPUT_DIR=.local/output

# garminconnect tokenstore override. Defaults to GARMIN_TOKEN_DIR.
# GARMIN_TOKENSTORE=.local/tokens
