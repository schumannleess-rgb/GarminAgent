# Garmin Agent Configuration
# Copy this file to .env and fill in your credentials
#
# ⚠️ DO NOT commit .env to Git (it's in .gitignore)

# ==========================================
# Garmin Credentials (首次登录需要)
# 登录后 TOKEN 会存储到 ./tokens/，之后不需要密码
# ==========================================
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password

# ==========================================
# LLM API Key (必需)
# 支持两种命名方式，选一种即可：

# 方式1: ANTHROPIC_* (StepFun 等 Anthropic 兼容 API)
ANTHROPIC_AUTH_TOKEN=your_api_key_here
ANTHROPIC_BASE_URL=https://api.stepfun.com/step_plan
ANTHROPIC_DEFAULT_FABLE_MODEL=step-3.7-flash

# 方式2: ZHIPU_* (智谱 GLM 等)
# ZHIPU_API_KEY=your_api_key_here
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/anthropic
# ZHIPU_MODEL=glm-4.7

# ==========================================
# 可选：使用代理或本地模型
# ==========================================
# ZHIPU_BASE_URL=https://your-proxy/api/anthropic
# ZHIPU_MODEL=claude-3-5-sonnet-20241022

# ==========================================
# External Paths (外部路径)
# ==========================================
# Garmin token 存储目录（留空则使用默认 ~/.garminconnect）
GARMIN_TOKENSTORE=